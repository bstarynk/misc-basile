# Basile STARYNKEVITCH ~/.zshrc file

source /etc/zsh/zshrc
limit coredumpsize 4900m
export REFPERSYS_TOPDIR=$HOME/RefPerSys
export PATH=$HOME/bin:$HOME/scripts:/usr/local/bin:/usr/bin:/bin:/sbin:/usr/sbin


### start xosview with a fping to several distant servers
function fpingxosview() {
    /usr/bin/fping --period=6500 --loop --stats ftp.lip6.fr ftp.gnu.org ftp.cea.fr websupport.se > $HOME/tmp/fping.out &
    /usr/bin/xosview &
}
### indent $1 using astyle for RefPerSys source code in C++ or C
function rpsastyle() {
    /usr/bin/astyle --verbose --style=gnu  --indent=spaces=2  --convert-tabs $1
}

### related to refpersys.org
### list the C++ public names defined in ELF files
function rpspubsym() {
    /usr/bin/nm --demangle  --extern-only    --defined-only  $* | /bin/grep -i rps
}


### list the C++ external names defined in ELF files
function rpsextsym()  {
    /usr/bin/nm --demangle  --extern-only   --undefined-only  $* | /bin/grep -i rps
}


### set the RefPerSys relevant environment variables for make config
### see file tools/do-configure-refpersys.c of RefPerSys on github
function rpsbatchconfig() {
   export CC=$(which gcc)
   export CXX=$(which g++)
   export CXXFLAGS='-O -g -fPIC -Wall'
   export RPS_BUILDER_PERSON=$(awk '/name/{print $3, $4}' ~/.gitconfig)
   export RPS_BUILDER_EMAIL=$(awk '/email/{print $3}' ~/.gitconfig)
   printf "rpsbatchconfig exports CC=%s CXX=%s CXXFLAGS='%s'\n" \
          $CC $CXX $CXXFLAGS
   printf "rpsbatchconfig exports RPS_BUILDER_PERSON='%s'\n" \
          $RPS_BUILDER_PERSON
   printf "rpsbatchconfig exports RPS_BUILDER_EMAIL='%s'\n" \
          $RPS_BUILDER_EMAIL
}

if [ -d ~/misc-basile -a !  ~/.zshrc -ef  ~/misc-basile/zshrc-basile ] 
then
	if /bin/cmp --silent ~/misc-basile/zshrc-basile .$HOME/zshrc ; then
      /bin/cp -vb $HOME/.zshrc $HOME/tmp/zshrc
      /bin/cp -vfa ~/misc-basile/zshrc-basile $HOME/.zshrc
      echo updated zshrc
    fi
fi


# BEGIN opam configuration
# This is useful if you're using opam as it adds:
#   - the correct directories to the PATH
#   - auto-completion for the opam binary
# This section can be safely removed at any time if needed.
[[ ! -r ~/.opam/opam-init/init.zsh ]] || source ~/.opam/opam-init/init.zsh > /dev/null 2> /dev/null
# END opam configuration
